{
    "version": 2,
    "public": true,
    "rewrites": [
        { "source": "/build/(.*)", "destination": "/public/build/$1" },
        { "source": "/images/(.*)", "destination": "/public/images/$1" },
        { "source": "/favicon.ico", "destination": "/public/favicon.ico" },
        { "source": "/robots.txt", "destination": "/public/robots.txt" },
        { "source": "/(.*)", "destination": "/api/index.php" }
    ],
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.6.0"
        }
    }
}
