{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": { "runtime": "vercel-phpa0.7.3" }
    },
    "routes": [
        {
            "src": "/build/( .* )",
            "dest": "/build/$1"
        },
        {
            "src": "/( .* \\.( ?: css|js|png|jpg|jpeg|gif|svg|ico)",
            "dest": "/public/$1"
        },
        {
            "src": "/( .* )",
            "dest": "/api/index.php"
        }
    ],
    "outputDirectory": "public",
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URĻ": "https://your-app-name.vercel.app",
        "APP_KEY": "base64:kH+0VEW/DZPdRCbn6bJdug4tFn3H9YyzMG+DEdHHB6U=",

        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "VIEW_COMPILED_PATH": "/tmp",

        "CACHE_DRIVER": "array",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie"
    }
}
