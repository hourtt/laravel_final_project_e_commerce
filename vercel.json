{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.3",
            "regions": ["sin1"]
        }
    },
    "routes": [
        {
            "src": "/(build|images|css|js|storage)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/robots.txt",
            "dest": "/public/robots.txt"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "https://laravel-project-e-commerce.vercel.app",
        "APP_KEY": "base64:kH+0VEW/DZPdRCbn6bJdug4tFn3H9YyzMG+DEdHHB6U=",

        "DB_CONNECTION": "pgsql",
        "DB_URL": "postgresql://postgres.dxxexcrbexmaqumvxeuo:NBxYlonkLPftAIkG@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres",

        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "VIEW_COMPILED_PATH": "/tmp",

        "CACHE_DRIVER": "array",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie"
    }
}
